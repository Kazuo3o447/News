# Environment Variables – IT News Hub

# === GROQ ===
GROQ_API_KEY=your_groq_api_key_here
# Starkes Modell (Default). Sparoption: llama-3.1-8b-instant
GROQ_MODEL=openai/gpt-oss-120b

# === AZURE ===
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your_cosmos_key_here
AZURE_COSMOS_DB=newsdb
AZURE_COSMOS_CONTAINER=articles

# === APP ===
APP_ENV=development
APP_SECRET_KEY=change_me_in_production
FEED_REFRESH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FEED=50

# === SICHERHEIT ===
# Shared-Secret für POST /api/refresh; leer = kein Auth-Check (nur Dev!)
REFRESH_SECRET=
# Optionaler Base-URL für "Ticket erstellen"-Hook im Frontend (HaloITSM o.ä.)
HALO_TICKET_BASE_URL=

# === PLATTFORM ===
# Fallback-Plattform wenn LLM + Regelschicht keinen Wert liefern
DEFAULT_PLATFORM=cross

# === MONITORING ===
APPLICATIONINSIGHTS_CONNECTION_STRING=your_appinsights_connection_string
