# Environment Variables – IT News Hub

# === GROQ ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# === AZURE ===
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=your_cosmos_key_here
AZURE_COSMOS_DB=newsdb
AZURE_COSMOS_CONTAINER=articles

# === APP ===
APP_ENV=development
APP_SECRET_KEY=change_me_in_production
FEED_REFRESH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_FEED=50

# === MONITORING ===
APPLICATIONINSIGHTS_CONNECTION_STRING=your_appinsights_connection_string
